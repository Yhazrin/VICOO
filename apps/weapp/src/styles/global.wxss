/* Vicoo Global Styles - Neo-brutalism Design System */

/* Color Palette - 匹配 Web 端 */
page {
  --primary: #FFD166;
  --primary-dark: #F59E0B;
  --secondary: #06D6A0;
  --accent: #EF476F;
  --info: #118AB2;
  --ink: #1a1a1a;
  --white: #ffffff;
  --light: #f9fafb;
  --dark: #111827;
  --gray-100: #f3f4f6;
  --gray-200: #e5e7eb;
  --gray-300: #d1d5db;
  --gray-400: #9ca3af;
  --gray-500: #6b7280;
  --gray-600: #4b5563;
  --gray-700: #374151;
  --gray-800: #1f2937;
  --gray-900: #111827;

  background-color: var(--light);
  color: var(--ink);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}

/* Dark Mode Support */
page.dark {
  --ink: #f3f4f6;
  --light: #111827;
  --white: #1f2937;
  --gray-100: #1f2937;
  --gray-200: #374151;
  --gray-300: #4b5563;
  --gray-400: #6b7280;
  --gray-500: #9ca3af;
}

/* Neo-brutalism Card - 匹配 Web 端 NeoCard */
.neo-card {
  background: var(--white);
  border: 3rpx solid var(--ink);
  border-radius: 16rpx;
  box-shadow: 4rpx 4rpx 0rpx 0rpx var(--ink);
  padding: 24rpx;
  margin: 16rpx;
  transition: all 0.2s ease;
}

.neo-card:active {
  transform: translate(2rpx, 2rpx);
  box-shadow: 2rpx 2rpx 0rpx 0rpx var(--ink);
}

.neo-card-primary {
  background: var(--primary);
  border-color: var(--ink);
}

.neo-card-secondary {
  background: var(--secondary);
  border-color: var(--ink);
}

.neo-card-accent {
  background: var(--accent);
  color: var(--white);
}

.neo-card-info {
  background: var(--info);
  color: var(--white);
}

/* Neo-brutalism Button - 匹配 Web 端 NeoButton */
.neo-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  border: 2rpx solid var(--ink);
  border-radius: 12rpx;
  background: var(--white);
  box-shadow: 2rpx 2rpx 0rpx 0rpx var(--ink);
  font-weight: 700;
  font-size: 26rpx;
  transition: all 0.1s ease;
}

.neo-button:active {
  transform: translate(2rpx, 2rpx);
  box-shadow: 1rpx 1rpx 0rpx 0rpx var(--ink);
}

.neo-button-primary {
  background: var(--primary);
}

.neo-button-primary:hover,
.neo-button-primary:active {
  background: var(--primary-dark);
}

.neo-button-secondary {
  background: var(--gray-200);
}

.neo-button-secondary:active {
  background: var(--gray-300);
}

.neo-button-ghost {
  background: transparent;
  border-color: transparent;
  box-shadow: none;
}

.neo-button-ghost:active {
  background: var(--gray-100);
  transform: none;
  box-shadow: none;
}

.neo-button-sm {
  padding: 8rpx 16rpx;
  font-size: 24rpx;
}

.neo-button-lg {
  padding: 24rpx 32rpx;
  font-size: 30rpx;
}

/* Input */
.neo-input {
  width: 100%;
  padding: 20rpx 24rpx;
  border: 2rpx solid var(--ink);
  border-radius: 12rpx;
  background: var(--white);
  font-size: 28rpx;
  box-sizing: border-box;
}

.neo-input:focus,
.neo-input:focus-within {
  outline: none;
  box-shadow: 4rpx 4rpx 0rpx 0rpx var(--primary);
}

/* Tags - 匹配 Web 端样式 */
.neo-tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 12rpx;
  border: 2rpx solid var(--ink);
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.neo-tag-idea {
  background: var(--secondary);
}

.neo-tag-code {
  background: var(--info);
  color: var(--white);
  border-color: var(--info);
}

.neo-tag-design {
  background: var(--accent);
  color: var(--white);
  border-color: var(--accent);
}

.neo-tag-meeting {
  background: var(--primary);
}

.neo-tag-default {
  background: var(--gray-200);
}

/* Typography - 匹配 Web 端 */
.title-large {
  font-size: 44rpx;
  font-weight: 900;
  letter-spacing: -1rpx;
  line-height: 1.2;
}

.title-medium {
  font-size: 34rpx;
  font-weight: 700;
}

.title-small {
  font-size: 28rpx;
  font-weight: 600;
}

.text-body {
  font-size: 28rpx;
  font-weight: 400;
  line-height: 1.6;
}

.text-caption {
  font-size: 22rpx;
  color: var(--gray-500);
}

.text-xs {
  font-size: 20rpx;
}

.text-sm {
  font-size: 24rpx;
}

/* Layout */
.container {
  padding: 24rpx;
  min-height: 100vh;
  background: var(--light);
}

.flex {
  display: flex;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-row {
  display: flex;
  flex-direction: row;
}

.items-center {
  align-items: center;
}

.justify-between {
  justify-content: space-between;
}

.justify-center {
  justify-content: center;
}

.justify-start {
  justify-content: flex-start;
}

.flex-1 {
  flex: 1;
}

.flex-wrap {
  flex-wrap: wrap;
}

.gap-xs { gap: 4rpx; }
.gap-sm { gap: 8rpx; }
.gap-md { gap: 16rpx; }
.gap-lg { gap: 24rpx; }
.gap-xl { gap: 32rpx; }

/* Spacing */
.m-0 { margin: 0; }
.mt-xs { margin-top: 4rpx; }
.mt-sm { margin-top: 8rpx; }
.mt-md { margin-top: 16rpx; }
.mt-lg { margin-top: 24rpx; }
.mt-xl { margin-top: 32rpx; }

.mb-xs { margin-bottom: 4rpx; }
.mb-sm { margin-bottom: 8rpx; }
.mb-md { margin-bottom: 16rpx; }
.mb-lg { margin-bottom: 24rpx; }
.mb-xl { margin-bottom: 32rpx; }

.ml-sm { margin-left: 8rpx; }
.ml-md { margin-left: 16rpx; }
.ml-lg { margin-left: 24rpx; }

.mr-sm { margin-right: 8rpx; }
.mr-md { margin-right: 16rpx; }
.mr-lg { margin-right: 24rpx; }

.p-0 { padding: 0; }
.p-xs { padding: 4rpx; }
.p-sm { padding: 8rpx; }
.p-md { padding: 16rpx; }
.p-lg { padding: 24rpx; }
.p-xl { padding: 32rpx; }

/* Width/Height */
.w-full { width: 100%; }
.h-full { height: 100%; }
.h-screen { height: 100vh; }
.w-auto { width: auto; }
.h-auto { height: auto; }

/* Rounded */
.rounded { border-radius: 8rpx; }
.rounded-lg { border-radius: 16rpx; }
.rounded-xl { border-radius: 20rpx; }
.rounded-full { border-radius: 9999rpx; }

/* Border */
.border { border: 2rpx solid var(--ink); }
.border-2 { border: 2rpx solid var(--ink); }
.border-3 { border: 3rpx solid var(--ink); }
.border-t { border-top: 2rpx solid var(--ink); }
.border-b { border-bottom: 2rpx solid var(--ink); }

/* Colors */
.bg-primary { background-color: var(--primary); }
.bg-secondary { background-color: var(--secondary); }
.bg-accent { background-color: var(--accent); }
.bg-info { background-color: var(--info); }
.bg-white { background-color: var(--white); }
.bg-light { background-color: var(--light); }
.bg-gray-100 { background-color: var(--gray-100); }
.bg-gray-200 { background-color: var(--gray-200); }

.text-ink { color: var(--ink); }
.text-white { color: var(--white); }
.text-gray-500 { color: var(--gray-500); }
.text-gray-400 { color: var(--gray-400); }
.text-primary { color: var(--primary); }
.text-secondary { color: var(--secondary); }
.text-accent { color: var(--accent); }

/* Animations */
@keyframes pop {
  0% { transform: scale(0.95); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

@keyframes fadeIn {
  0% { opacity: 0; }
  100% { opacity: 1; }
}

@keyframes slideUp {
  0% { transform: translateY(20rpx); opacity: 0; }
  100% { transform: translateY(0); opacity: 1; }
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.animate-pop {
  animation: pop 0.3s ease-out;
}

.animate-fadeIn {
  animation: fadeIn 0.3s ease-out;
}

.animate-slideUp {
  animation: slideUp 0.3s ease-out;
}

.animate-spin {
  animation: spin 1s linear infinite;
}

/* Loading */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--gray-200);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  text-align: center;
}

.empty-state-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-state-text {
  font-size: 28rpx;
  color: var(--gray-500);
}

/* Avatar */
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 2rpx solid var(--ink);
  object-fit: cover;
}

.avatar-sm {
  width: 48rpx;
  height: 48rpx;
}

.avatar-lg {
  width: 120rpx;
  height: 120rpx;
}

/* Divider */
.divider {
  height: 2rpx;
  background: var(--gray-200);
  margin: 24rpx 0;
}

.divider-vertical {
  width: 2rpx;
  background: var(--gray-200);
  margin: 0 16rpx;
}

/* Badge */
.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
  font-size: 22rpx;
  font-weight: 700;
  border-radius: 18rpx;
  background: var(--primary);
  color: var(--ink);
}

/* Scrollbar */
::-webkit-scrollbar {
  display: none;
}

/* Safe Area */
.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

.safe-area-top {
  padding-top: env(safe-area-inset-top);
}

/* Icon using text symbols */
.icon {
  font-style: normal;
  font-weight: normal;
}
