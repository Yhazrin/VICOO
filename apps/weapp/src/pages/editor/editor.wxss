/* pages/editor/editor.wxss - Editor Page Styles */

.container {
  min-height: 100vh;
  background: var(--light);
  display: flex;
  flex-direction: column;
}

/* Loading */
.loading-container {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--gray-200);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

/* Editor Wrapper */
.editor-wrapper {
  flex: 1;
  display: flex;
  flex-direction: column;
}

/* Toolbar */
.toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  background: var(--white);
  border-bottom: 3rpx solid var(--ink);
  position: sticky;
  top: 0;
  z-index: 10;
}

.toolbar-left,
.toolbar-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.toolbar-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
  transition: all 0.2s ease;
}

.toolbar-btn:active {
  background: var(--gray-100);
}

.toolbar-btn .icon {
  font-size: 32rpx;
  color: var(--ink);
}

.toolbar-label {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--gray-500);
}

.toolbar-divider {
  width: 2rpx;
  height: 32rpx;
  background: var(--gray-200);
  margin: 0 8rpx;
}

/* Save Status */
.save-status {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: var(--gray-500);
}

.save-status.saved {
  color: var(--secondary);
}

.save-status .icon {
  font-size: 24rpx;
}

/* Publish Toggle */
.publish-toggle {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.publish-label {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--gray-500);
  text-transform: uppercase;
}

.publish-label.public {
  color: var(--secondary);
}

.toggle-switch {
  width: 80rpx;
  height: 40rpx;
  background: var(--gray-200);
  border: 2rpx solid var(--ink);
  border-radius: 20rpx;
  padding: 2rpx;
  position: relative;
  transition: all 0.2s ease;
}

.toggle-switch.active {
  background: var(--primary);
}

.toggle-knob {
  width: 32rpx;
  height: 32rpx;
  background: var(--white);
  border: 2rpx solid var(--ink);
  border-radius: 50%;
  transition: all 0.2s ease;
}

.toggle-switch.active .toggle-knob {
  transform: translateX(40rpx);
}

/* Editor Content */
.editor-content {
  flex: 1;
  padding: 24rpx;
  padding-bottom: 120rpx;
}

/* Category Selector */
.category-selector {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
  overflow-x: auto;
  padding-bottom: 8rpx;
}

.category-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 16rpx;
  border: 2rpx solid var(--gray-300);
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: var(--gray-500);
  white-space: nowrap;
  transition: all 0.2s ease;
}

.category-btn .icon {
  font-size: 24rpx;
}

.category-btn.active {
  background: var(--primary);
  border-color: var(--ink);
  color: var(--ink);
}

/* Title Section */
.title-section {
  margin-bottom: 24rpx;
}

.title-input {
  width: 100%;
  font-size: 44rpx;
  font-weight: 900;
  color: var(--ink);
  border: none;
  background: transparent;
  padding: 0;
  line-height: 1.3;
}

.title-placeholder {
  color: var(--gray-300);
}

/* Summary Card */
.summary-card {
  background: var(--gray-100);
  border: 2rpx solid var(--ink);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
}

.summary-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.summary-header .icon {
  font-size: 28rpx;
  color: var(--primary);
}

.summary-title {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--ink);
}

.summary-content {
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--gray-600);
  margin-bottom: 12rpx;
}

.summary-actions {
  display: flex;
  gap: 16rpx;
}

.summary-action {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--gray-500);
  text-decoration: underline;
}

/* Content Input */
.content-input {
  width: 100%;
  min-height: 400rpx;
  font-size: 30rpx;
  line-height: 1.8;
  color: var(--ink);
  border: none;
  background: transparent;
  padding: 0;
}

.content-placeholder {
  color: var(--gray-300);
}

/* Links Section */
.links-section {
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 2rpx dashed var(--gray-200);
}

.links-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.links-header .icon {
  font-size: 28rpx;
  color: var(--gray-400);
}

.links-title {
  font-size: 24rpx;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1rpx;
  color: var(--gray-500);
}

.links-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.link-item {
  display: flex;
  align-items: center;
  background: var(--white);
  border: 2rpx dashed var(--primary);
  border-radius: 8rpx;
  padding: 8rpx 12rpx;
}

.link-icon {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--primary);
}

.link-text {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--ink);
}

/* Concepts Section */
.concepts-section {
  margin-top: 24rpx;
}

.concepts-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.concepts-header .icon {
  font-size: 28rpx;
  color: var(--gray-400);
}

.concepts-title {
  font-size: 24rpx;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1rpx;
  color: var(--gray-500);
}

.concepts-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.concept-item {
  display: flex;
  flex-direction: column;
  background: var(--white);
  border: 2rpx solid var(--ink);
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
}

.concept-term {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--ink);
}

.concept-type {
  font-size: 20rpx;
  font-weight: 600;
  color: var(--gray-500);
  text-transform: uppercase;
}

/* Bottom Actions */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  background: var(--white);
  border-top: 3rpx solid var(--ink);
  z-index: 10;
}

.bottom-actions .neo-button {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.bottom-actions .icon {
  font-size: 28rpx;
}

/* Text Colors */
.text-accent {
  color: var(--accent) !important;
}

/* Animations */
@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.animate-spin {
  animation: spin 1s linear infinite;
}

@keyframes pop {
  0% { transform: scale(0.95); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

.animate-pop {
  animation: pop 0.3s ease-out;
}

/* Safe Area */
.safe-area-bottom {
  height: 40rpx;
}

/* Material Icons */
.icon {
  font-family: 'Material Icons';
  font-weight: normal;
  font-style: normal;
  font-size: 24rpx;
  line-height: 1;
  letter-spacing: normal;
  text-transform: none;
  display: inline-block;
  white-space: nowrap;
  word-wrap: normal;
  direction: ltr;
}
