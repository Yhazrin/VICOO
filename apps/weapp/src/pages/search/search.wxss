/* pages/search/search.wxss - Search Page Styles */

.container {
  padding: 24rpx;
  min-height: 100vh;
  background: var(--light);
}

/* Header */
.header {
  margin-bottom: 24rpx;
}

.title-large {
  font-size: 40rpx;
  font-weight: 900;
  color: var(--ink);
}

/* Search Section */
.search-section {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.search-bar {
  flex: 1;
  display: flex;
  align-items: center;
  background: var(--white);
  border: 2rpx solid var(--ink);
  border-radius: 12rpx;
  padding: 0 16rpx;
  box-shadow: 2rpx 2rpx 0rpx 0rpx var(--ink);
}

.search-icon {
  font-size: 32rpx;
  color: var(--gray-400);
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: var(--ink);
}

.search-placeholder {
  color: var(--gray-400);
}

.clear-icon {
  font-size: 32rpx;
  color: var(--gray-400);
  padding: 8rpx;
}

.ai-button {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 0 24rpx;
  background: var(--gray-100);
  border: 2rpx solid var(--ink);
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--gray-500);
  transition: all 0.2s ease;
}

.ai-button.active {
  background: var(--primary);
  color: var(--ink);
}

.ai-button:active {
  transform: translate(1rpx, 1rpx);
}

.ai-button .icon {
  font-size: 28rpx;
}

/* Quick Actions */
.quick-actions {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.quick-action {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 16rpx;
  background: var(--white);
  border: 2rpx solid var(--gray-200);
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.quick-action:active {
  border-color: var(--ink);
  background: var(--gray-50);
}

.quick-action .icon {
  font-size: 32rpx;
  color: var(--primary);
}

.quick-action text:last-child {
  font-size: 20rpx;
  font-weight: 600;
  color: var(--gray-600);
}

/* Tabs */
.tabs {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
  border-bottom: 2rpx solid var(--gray-200);
  padding-bottom: 16rpx;
}

.tab {
  padding: 10rpx 20rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--gray-500);
  border-radius: 8rpx;
  transition: all 0.2s ease;
}

.tab.active {
  background: var(--primary);
  color: var(--ink);
}

/* Content */
.content {
  flex: 1;
}

/* AI Response */
.ai-response {
  background: var(--white);
  border: 3rpx solid var(--ink);
  border-radius: 16rpx;
  box-shadow: 4rpx 4rpx 0rpx 0rpx var(--ink);
  padding: 20rpx;
  margin-bottom: 24rpx;
}

.ai-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.ai-avatar {
  width: 56rpx;
  height: 56rpx;
  background: var(--primary);
  border: 2rpx solid var(--ink);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ai-avatar .icon {
  font-size: 32rpx;
  color: var(--ink);
}

.ai-info {
  display: flex;
  flex-direction: column;
}

.ai-name {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--ink);
}

.ai-status {
  font-size: 20rpx;
  color: var(--gray-500);
}

.ai-content {
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--gray-600);
}

.ai-thinking {
  display: inline-flex;
}

.typing-dot {
  animation: typing 1.4s infinite;
  font-weight: 900;
  font-size: 40rpx;
  color: var(--primary);
}

.typing-dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes typing {
  0%, 60%, 100% { opacity: 0; }
  30% { opacity: 1; }
}

/* Results List */
.results-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.result-card {
  background: var(--white);
  border: 2rpx solid var(--ink);
  border-radius: 12rpx;
  padding: 20rpx;
  transition: all 0.2s ease;
}

.result-card:active {
  transform: translate(2rpx, 2rpx);
  box-shadow: 1rpx 1rpx 0rpx 0rpx var(--ink);
}

.result-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.result-icon {
  font-size: 24rpx;
  color: var(--gray-400);
}

.result-type {
  font-size: 20rpx;
  font-weight: 600;
  color: var(--gray-500);
  text-transform: uppercase;
}

.result-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--ink);
  margin-bottom: 8rpx;
}

.result-snippet {
  font-size: 24rpx;
  line-height: 1.4;
  color: var(--gray-500);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* Recent Section */
.recent-section {
  margin-top: 20rpx;
}

.recent-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.recent-title {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--gray-500);
}

.recent-clear {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--accent);
}

.recent-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.recent-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  background: var(--white);
  border: 2rpx solid var(--gray-100);
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.recent-item:active {
  border-color: var(--ink);
}

.recent-item .icon {
  font-size: 24rpx;
  color: var(--gray-400);
}

.recent-item text:last-child {
  font-size: 26rpx;
  color: var(--ink);
}

/* Loading */
.loading-container {
  padding: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--gray-200);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  text-align: center;
}

.empty-state-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-state-text {
  font-size: 28rpx;
  color: var(--gray-500);
}

/* Animations */
@keyframes pop {
  0% { transform: scale(0.95); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

.animate-pop {
  animation: pop 0.3s ease-out;
}

/* Safe Area */
.safe-area-bottom {
  height: 40rpx;
}

/* Material Icons */
.icon {
  font-family: 'Material Icons';
  font-weight: normal;
  font-style: normal;
  font-size: 24rpx;
  line-height: 1;
  letter-spacing: normal;
  text-transform: none;
  display: inline-block;
  white-space: nowrap;
  word-wrap: normal;
  direction: ltr;
}
