/* pages/ai/ai.wxss - AI Chat Page Styles */

.container {
  min-height: 100vh;
  background: var(--light);
  display: flex;
  flex-direction: column;
  padding-bottom: 120rpx;
}

/* Header */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: var(--white);
  border-bottom: 3rpx solid var(--ink);
  position: sticky;
  top: 0;
  z-index: 10;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.ai-avatar {
  width: 64rpx;
  height: 64rpx;
  background: var(--primary);
  border: 3rpx solid var(--ink);
  border-radius: 16rpx;
  box-shadow: 2rpx 2rpx 0rpx 0rpx var(--ink);
  display: flex;
  align-items: center;
  justify-content: center;
}

.ai-avatar .icon {
  font-size: 36rpx;
  color: var(--ink);
}

.header-info {
  display: flex;
  flex-direction: column;
}

.header-title {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--ink);
}

.header-status {
  font-size: 22rpx;
  color: var(--secondary);
}

.header-actions {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  width: 56rpx;
  height: 56rpx;
  background: var(--gray-100);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn .icon {
  font-size: 32rpx;
  color: var(--gray-500);
}

/* Welcome Screen */
.welcome-screen {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.welcome-icon {
  width: 120rpx;
  height: 120rpx;
  background: var(--primary);
  border: 3rpx solid var(--ink);
  border-radius: 24rpx;
  box-shadow: 4rpx 4rpx 0rpx 0rpx var(--ink);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.welcome-icon .icon {
  font-size: 64rpx;
  color: var(--ink);
}

.welcome-title {
  font-size: 36rpx;
  font-weight: 900;
  color: var(--ink);
  text-align: center;
  margin-bottom: 8rpx;
}

.welcome-subtitle {
  font-size: 28rpx;
  color: var(--gray-500);
  text-align: center;
  margin-bottom: 40rpx;
}

/* Quick Prompts */
.quick-prompts {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  width: 100%;
}

.quick-prompt {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx;
  background: var(--white);
  border: 2rpx solid var(--ink);
  border-radius: 16rpx;
  box-shadow: 2rpx 2rpx 0rpx 0rpx var(--ink);
  transition: all 0.2s ease;
}

.quick-prompt:active {
  transform: translate(1rpx, 1rpx);
  box-shadow: 1rpx 1rpx 0rpx 0rpx var(--ink);
}

.quick-prompt .icon {
  font-size: 32rpx;
  color: var(--primary);
}

.quick-prompt text:last-child {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--ink);
}

/* Messages Container */
.messages-container {
  flex: 1;
  padding: 24rpx;
  padding-bottom: 40rpx;
}

/* Message */
.message {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.message-user {
  flex-direction: row-reverse;
}

.message-avatar {
  width: 48rpx;
  height: 48rpx;
  background: var(--primary);
  border: 2rpx solid var(--ink);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.message-avatar .icon {
  font-size: 28rpx;
  color: var(--ink);
}

.message-content {
  max-width: 80%;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  position: relative;
}

.message-user .message-content {
  background: var(--primary);
  border: 2rpx solid var(--ink);
  box-shadow: 2rpx 2rpx 0rpx 0rpx var(--ink);
}

.message-assistant .message-content {
  background: var(--white);
  border: 2rpx solid var(--gray-200);
}

.message-text {
  font-size: 28rpx;
  line-height: 1.5;
  color: var(--ink);
  white-space: pre-wrap;
}

.message-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 8rpx;
  padding-top: 8rpx;
  border-top: 1rpx solid var(--gray-100);
}

.message-action {
  opacity: 0.5;
  transition: opacity 0.2s ease;
}

.message-action:active {
  opacity: 1;
}

.message-action .icon {
  font-size: 22rpx;
  color: var(--gray-500);
}

/* Typing Indicator */
.typing-content {
  padding: 16rpx 24rpx;
}

.typing-indicator {
  display: flex;
  gap: 8rpx;
}

.typing-dot {
  width: 12rpx;
  height: 12rpx;
  background: var(--gray-400);
  border-radius: 50%;
  animation: typing 1.4s infinite;
}

.typing-dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes typing {
  0%, 60%, 100% { transform: translateY(0); opacity: 0.5; }
  30% { transform: translateY(-8rpx); opacity: 1; }
}

/* Input Area */
.input-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 24rpx;
  background: var(--white);
  border-top: 3rpx solid var(--ink);
  z-index: 10;
}

.input-wrapper {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: var(--gray-100);
  border: 2rpx solid var(--ink);
  border-radius: 24rpx;
  padding: 8rpx 8rpx 8rpx 20rpx;
}

.input-field {
  flex: 1;
  padding: 12rpx 0;
  font-size: 28rpx;
  color: var(--ink);
}

.input-placeholder {
  color: var(--gray-400);
}

.send-btn {
  width: 64rpx;
  height: 64rpx;
  background: var(--gray-200);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.send-btn.active {
  background: var(--primary);
}

.send-btn .icon {
  font-size: 28rpx;
  color: var(--gray-500);
}

.send-btn.active .icon {
  color: var(--ink);
}

/* Safe Area */
.safe-area-bottom {
  height: 40rpx;
}

/* Material Icons */
.icon {
  font-family: 'Material Icons';
  font-weight: normal;
  font-style: normal;
  font-size: 24rpx;
  line-height: 1;
  letter-spacing: normal;
  text-transform: none;
  display: inline-block;
  white-space: nowrap;
  word-wrap: normal;
  direction: ltr;
}
