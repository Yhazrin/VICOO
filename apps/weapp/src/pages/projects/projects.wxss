/* pages/projects/projects.wxss - Projects Page Styles */

.container {
  min-height: 100vh;
  background: var(--light);
  padding: 24rpx;
}

/* Header */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.title-large {
  font-size: 40rpx;
  font-weight: 900;
  color: var(--ink);
}

.header .neo-button {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.header .icon {
  font-size: 28rpx;
}

/* Kanban Board */
.kanban-board {
  display: flex;
  gap: 16rpx;
  overflow-x: auto;
  padding-bottom: 20rpx;
  -webkit-overflow-scrolling: touch;
}

/* Column */
.kanban-column {
  flex-shrink: 0;
  width: 280rpx;
  border-radius: 16rpx;
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  max-height: calc(100vh - 200rpx);
}

.column-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid var(--ink);
}

.column-title {
  font-size: 26rpx;
  font-weight: 800;
  color: var(--ink);
  text-transform: uppercase;
}

.column-count {
  width: 36rpx;
  height: 36rpx;
  background: var(--white);
  border: 2rpx solid var(--ink);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  color: var(--ink);
}

/* Tasks List */
.tasks-list {
  flex: 1;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  min-height: 200rpx;
}

/* Task Card */
.task-card {
  background: var(--white);
  border: 2rpx solid var(--ink);
  border-radius: 12rpx;
  padding: 16rpx;
  box-shadow: 2rpx 2rpx 0rpx 0rpx var(--ink);
  transition: all 0.2s ease;
}

.task-card:active {
  transform: scale(0.98);
}

.task-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.priority-badge {
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  font-size: 18rpx;
  font-weight: 700;
  text-transform: uppercase;
}

.task-delete {
  opacity: 0;
  transition: opacity 0.2s ease;
}

.task-card:active .task-delete {
  opacity: 1;
}

.task-delete .icon {
  font-size: 24rpx;
  color: var(--gray-400);
}

.task-title {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--ink);
  line-height: 1.3;
}

.task-description {
  font-size: 22rpx;
  color: var(--gray-500);
  margin-top: 8rpx;
  line-height: 1.4;
}

.task-link {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-top: 12rpx;
  padding-top: 10rpx;
  border-top: 1rpx solid var(--gray-100);
}

.task-link .icon {
  font-size: 20rpx;
  color: var(--primary);
}

.task-link text:last-child {
  font-size: 20rpx;
  font-weight: 600;
  color: var(--primary);
}

/* Empty Column */
.empty-column {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100rpx;
  border: 2rpx dashed var(--gray-300);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: var(--gray-400);
}

/* Modal */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(4rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: var(--white);
  border: 3rpx solid var(--ink);
  border-radius: 20rpx;
  box-shadow: 8rpx 8rpx 0rpx 0rpx var(--ink);
  width: 90%;
  max-width: 600rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 2rpx solid var(--gray-100);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--ink);
}

.modal-close .icon {
  font-size: 32rpx;
  color: var(--gray-400);
}

.modal-body {
  padding: 24rpx;
}

.priority-selector {
  margin-top: 20rpx;
}

.priority-label {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--gray-600);
  margin-bottom: 12rpx;
  display: block;
}

.priority-options {
  display: flex;
  gap: 12rpx;
}

.priority-option {
  flex: 1;
  padding: 12rpx;
  text-align: center;
  border: 2rpx solid var(--gray-300);
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--gray-500);
  transition: all 0.2s ease;
}

.priority-option.active {
  background: var(--primary);
  border-color: var(--ink);
  color: var(--ink);
}

.modal-footer {
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  border-top: 2rpx solid var(--gray-100);
}

/* Safe Area */
.safe-area-bottom {
  height: 40rpx;
}

/* Material Icons */
.icon {
  font-family: 'Material Icons';
  font-weight: normal;
  font-style: normal;
  font-size: 24rpx;
  line-height: 1;
  letter-spacing: normal;
  text-transform: none;
  display: inline-block;
  white-space: nowrap;
  word-wrap: normal;
  direction: ltr;
}
