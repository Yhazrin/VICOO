/* pages/index/index.wxss - Dashboard Styles */

.container {
  padding: 24rpx;
  min-height: 100vh;
  background: var(--light);
}

/* Header */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.brand {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.logo-container {
  width: 72rpx;
  height: 72rpx;
  background: var(--primary);
  border: 3rpx solid var(--ink);
  border-radius: 16rpx;
  box-shadow: 4rpx 4rpx 0rpx 0rpx var(--ink);
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo {
  font-size: 36rpx;
  font-weight: 900;
  color: var(--ink);
}

.brand-text {
  display: flex;
  flex-direction: column;
}

.brand-text .title-large {
  font-size: 40rpx;
  line-height: 1;
}

.user-area .avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 3rpx solid var(--ink);
  overflow: hidden;
  box-shadow: 2rpx 2rpx 0rpx 0rpx var(--ink);
}

.user-area .avatar image {
  width: 100%;
  height: 100%;
}

/* Focus Button */
.focus-button {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  background: var(--ink);
  border: 2rpx solid var(--ink);
  border-radius: 16rpx;
  box-shadow: 4rpx 4rpx 0rpx 0rpx rgba(255,255,255,0.2);
  margin-bottom: 32rpx;
  transition: all 0.2s ease;
}

.focus-button:active {
  transform: translate(2rpx, 2rpx);
  box-shadow: 2rpx 2rpx 0rpx 0rpx rgba(255,255,255,0.2);
}

.focus-icon {
  width: 48rpx;
  height: 48rpx;
  background: var(--primary);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.focus-icon .icon {
  font-size: 28rpx;
}

.focus-text {
  flex: 1;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--white);
}

.focus-arrow .icon {
  font-size: 32rpx;
  color: var(--gray-400);
}

/* Stats Section */
.stats-section {
  margin-bottom: 32rpx;
}

.section-title {
  font-weight: 700;
  color: var(--ink);
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.stat-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  background: var(--white);
  border: 3rpx solid var(--ink);
  border-radius: 16rpx;
  box-shadow: 4rpx 4rpx 0rpx 0rpx var(--ink);
  transition: all 0.2s ease;
}

.stat-card:active {
  transform: translate(2rpx, 2rpx);
  box-shadow: 2rpx 2rpx 0rpx 0rpx var(--ink);
}

.stat-card-primary {
  background: var(--primary);
}

.stat-card-secondary {
  background: var(--secondary);
}

.stat-card-info {
  background: var(--info);
}

.stat-card-accent {
  background: var(--accent);
  color: var(--white);
}

.stat-icon {
  width: 56rpx;
  height: 56rpx;
  background: var(--white);
  border: 2rpx solid var(--ink);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.stat-icon .icon {
  font-size: 32rpx;
}

.stat-card-accent .stat-icon {
  background: var(--accent);
}

.stat-card-accent .stat-icon .icon {
  color: var(--white);
}

.stat-info {
  display: flex;
  flex-direction: column;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1;
  color: var(--ink);
}

.stat-card-accent .stat-value {
  color: var(--white);
}

.stat-label {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--ink);
  opacity: 0.8;
  margin-top: 4rpx;
}

.stat-card-accent .stat-label {
  color: var(--white);
}

/* Actions Section */
.actions-section {
  margin-bottom: 32rpx;
}

.action-row {
  display: flex;
  gap: 16rpx;
}

.action-button {
  flex: 1;
  justify-content: center;
}

.action-button .icon {
  font-size: 28rpx;
}

/* Recent Section */
.recent-section {
  margin-bottom: 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.view-all {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--gray-500);
}

.view-all .icon {
  font-size: 28rpx;
}

/* Note Card */
.note-card {
  background: var(--white);
  border: 3rpx solid var(--ink);
  border-radius: 16rpx;
  box-shadow: 4rpx 4rpx 0rpx 0rpx var(--ink);
  padding: 24rpx;
  margin-bottom: 16rpx;
  transition: all 0.2s ease;
}

.note-card:active {
  transform: translate(2rpx, 2rpx);
  box-shadow: 2rpx 2rpx 0rpx 0rpx var(--ink);
}

.note-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.note-category {
  font-size: 20rpx;
  text-transform: capitalize;
}

.note-date {
  font-size: 22rpx;
  color: var(--gray-500);
  font-weight: 500;
}

.note-title {
  font-weight: 700;
  color: var(--ink);
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.note-snippet {
  font-size: 26rpx;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.note-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.tag {
  font-size: 20rpx;
  font-weight: 600;
  color: var(--gray-500);
  background: var(--gray-100);
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
}

/* Category Tags */
.neo-tag-default {
  background: var(--gray-200);
}

.neo-tag-idea {
  background: var(--secondary);
}

.neo-tag-code {
  background: var(--info);
  color: var(--white);
  border-color: var(--info);
}

.neo-tag-design {
  background: var(--accent);
  color: var(--white);
  border-color: var(--accent);
}

.neo-tag-meeting {
  background: var(--primary);
}

/* Loading */
.loading-container {
  padding: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--gray-200);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
  text-align: center;
}

.empty-state-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-state-text {
  font-size: 28rpx;
  color: var(--gray-500);
}

/* Animations */
@keyframes pop {
  0% { transform: scale(0.95); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

.animate-pop {
  animation: pop 0.3s ease-out forwards;
  opacity: 0;
}

/* Safe Area */
.safe-area-bottom {
  height: 40rpx;
}

/* Icon */
.icon {
  font-style: normal;
}
