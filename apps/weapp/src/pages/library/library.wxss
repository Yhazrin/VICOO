/* pages/library/library.wxss - Library Page Styles */

.container {
  padding: 24rpx;
  min-height: 100vh;
  background: var(--light);
  padding-bottom: 120rpx;
}

/* Header */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.title-large {
  font-size: 40rpx;
  font-weight: 900;
  color: var(--ink);
}

.header-actions {
  display: flex;
  gap: 16rpx;
}

.view-toggle {
  display: flex;
  background: var(--white);
  border: 2rpx solid var(--ink);
  border-radius: 12rpx;
  overflow: hidden;
}

.view-toggle .icon {
  padding: 12rpx 16rpx;
  font-size: 32rpx;
  color: var(--gray-400);
}

.view-toggle .icon.active {
  background: var(--primary);
  color: var(--ink);
}

/* Search Bar */
.search-bar {
  display: flex;
  align-items: center;
  background: var(--white);
  border: 2rpx solid var(--ink);
  border-radius: 12rpx;
  padding: 0 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 2rpx 2rpx 0rpx 0rpx var(--ink);
}

.search-icon {
  font-size: 32rpx;
  color: var(--gray-400);
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: var(--ink);
}

.search-placeholder {
  color: var(--gray-400);
}

.clear-icon {
  font-size: 32rpx;
  color: var(--gray-400);
  padding: 8rpx;
}

/* Filter Tabs */
.filter-tabs {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
  overflow-x: auto;
  padding-bottom: 8rpx;
}

.filter-tab {
  padding: 10rpx 20rpx;
  border: 2rpx solid var(--gray-300);
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--gray-500);
  white-space: nowrap;
  transition: all 0.2s ease;
}

.filter-tab.active {
  background: var(--primary);
  border-color: var(--ink);
  color: var(--ink);
}

/* Notes Container */
.notes-container {
  flex: 1;
}

/* Grid View */
.grid-view {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.grid-view .note-card {
  margin: 0;
}

/* List View */
.list-view .note-card {
  margin: 0 0 16rpx 0;
}

/* Note Card */
.note-card {
  background: var(--white);
  border: 3rpx solid var(--ink);
  border-radius: 16rpx;
  box-shadow: 4rpx 4rpx 0rpx 0rpx var(--ink);
  padding: 20rpx;
  transition: all 0.2s ease;
}

.note-card:active {
  transform: translate(2rpx, 2rpx);
  box-shadow: 2rpx 2rpx 0rpx 0rpx var(--ink);
}

.note-card-list {
  display: flex;
  flex-direction: column;
}

.note-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.note-category {
  font-size: 18rpx;
  text-transform: capitalize;
}

.note-date {
  font-size: 20rpx;
  color: var(--gray-500);
}

.note-title {
  font-weight: 700;
  color: var(--ink);
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.note-snippet {
  font-size: 24rpx;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.note-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.tag {
  font-size: 18rpx;
  font-weight: 600;
  color: var(--gray-500);
  background: var(--gray-100);
  padding: 4rpx 8rpx;
  border-radius: 6rpx;
}

/* Category Tags */
.neo-tag-default {
  background: var(--gray-200);
}

.neo-tag-idea {
  background: var(--secondary);
}

.neo-tag-code {
  background: var(--info);
  color: var(--white);
  border-color: var(--info);
}

.neo-tag-design {
  background: var(--accent);
  color: var(--white);
  border-color: var(--accent);
}

.neo-tag-meeting {
  background: var(--primary);
}

/* Text Colors */
.text-gray-500 {
  color: var(--gray-500);
}

/* FAB */
.fab {
  position: fixed;
  bottom: 60rpx;
  right: 32rpx;
  width: 100rpx;
  height: 100rpx;
  background: var(--primary);
  border: 3rpx solid var(--ink);
  border-radius: 50%;
  box-shadow: 4rpx 4rpx 0rpx 0rpx var(--ink);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  transition: all 0.2s ease;
}

.fab:active {
  transform: translate(2rpx, 2rpx);
  box-shadow: 2rpx 2rpx 0rpx 0rpx var(--ink);
}

.fab .icon {
  font-size: 48rpx;
  color: var(--ink);
}

/* Loading */
.loading-container {
  padding: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--gray-200);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  text-align: center;
}

.empty-state-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-state-text {
  font-size: 28rpx;
  color: var(--gray-500);
}

/* Safe Area */
.safe-area-bottom {
  height: 40rpx;
}

/* Material Icons */
.icon {
  font-family: 'Material Icons';
  font-weight: normal;
  font-style: normal;
  font-size: 24rpx;
  line-height: 1;
  letter-spacing: normal;
  text-transform: none;
  display: inline-block;
  white-space: nowrap;
  word-wrap: normal;
  direction: ltr;
}
