<!--pages/library/library.wxml - Library Page -->
<view class="container">
  <!-- Header -->
  <view class="header">
    <view class="title-large">Library</view>
    <view class="header-actions">
      <view class="view-toggle" bindtap="toggleViewMode">
        <text class="icon {{viewMode === 'grid' ? 'active' : ''}}">▦</text>
        <text class="icon {{viewMode === 'list' ? 'active' : ''}}">☰</text>
      </view>
    </view>
  </view>

  <!-- Search Bar -->
  <view class="search-bar">
    <text class="icon search-icon">🔍</text>
    <input 
      class="search-input" 
      placeholder="Search notes..." 
      placeholder-class="search-placeholder"
      value="{{searchQuery}}"
      bindinput="onSearch"
    />
    <text wx:if="{{searchQuery}}" class="icon clear-icon" bindtap="onSearch">✕</text>
  </view>

  <!-- Filter Tabs -->
  <view class="filter-tabs">
    <view 
      wx:for="{{categories}}" 
      wx:key="*this" 
      class="filter-tab {{filter === item ? 'active' : ''}}"
      data-filter="{{item}}"
      bindtap="setFilter"
    >
      {{item}}
    </view>
  </view>

  <!-- Notes Grid/List -->
  <view class="notes-container {{viewMode === 'grid' ? 'grid-view' : 'list-view'}}">
    <view wx:if="{{loading}}" class="loading-container">
      <view class="loading-spinner"></view>
      <text class="text-caption mt-md">Loading...</text>
    </view>

    <view wx:elif="{{filteredNotes.length === 0}}" class="empty-state">
      <view class="empty-state-icon">📚</view>
      <text class="empty-state-text">No notes found</text>
      <button class="neo-button neo-button-primary mt-lg" bindtap="createNote">Create Note</button>
    </view>

    <view wx:else>
      <view 
        wx:for="{{filteredNotes}}" 
        wx:key="id" 
        class="note-card {{viewMode === 'grid' ? '' : 'note-card-list'}}"
        data-id="{{item.id}}" 
        bindtap="goToEditor"
      >
        <view class="note-header">
          <view class="note-category neo-tag neo-tag-{{item.category || 'default'}}">
            {{item.category || 'note'}}
          </view>
          <text class="note-date">{{item.timestamp}}</text>
        </view>
        <view class="note-title title-small">{{item.title}}</view>
        <view class="note-snippet text-body text-gray-500">{{item.snippet || item.content}}</view>
        <view class="note-tags" wx:if="{{item.tags && item.tags.length > 0}}">
          <text wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this" class="tag">#{{tag}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- FAB - Create Note -->
  <view class="fab" bindtap="createNote">
    <text class="icon">+</text>
  </view>

  <!-- Safe Area -->
  <view class="safe-area-bottom"></view>
</view>
