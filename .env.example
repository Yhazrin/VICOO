# ==================== Vicoo Configuration ====================

# Server
PORT=8000
NODE_ENV=development
API_URL=http://localhost:8000

# JWT Secret (MUST change in production!)
JWT_SECRET=your-jwt-secret-here-change-in-production

# Database (SQLite for development)
DATABASE_URL=./data/vicoo.db

# CORS (comma-separated list of allowed origins)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,http://localhost:3001,http://localhost:3002

# ==================== AI Providers ====================

# MiniMax API (primary) — https://platform.minimaxi.com/
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_MODEL=M2-her
MINIMAX_BASE_URL=https://api.minimaxi.com/v1

# OpenAI (optional) — https://platform.openai.com/
OPENAI_API_KEY=

# Anthropic Claude (optional) — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Google Gemini (optional) — https://aistudio.google.com/
GEMINI_API_KEY=

# AI Provider preference (auto|minimax|openai|anthropic|gemini)
AI_PROVIDER=auto

# ==================== OAuth ====================

# Google OAuth — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# GitHub OAuth — https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ==================== Payment ====================

# Stripe — https://dashboard.stripe.com/
STRIPE_SECRET_KEY=

# WeChat Pay
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=

# Alipay
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=

# ==================== Optional ====================

# LangSmith (observability)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=vicoo

# Auto-generate knowledge graph on startup
ENABLE_AUTO_GRAPH=true
